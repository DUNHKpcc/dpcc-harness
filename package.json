{
  "name": "pcc-agent",
  "version": "2.1.3",
  "productName": "PccAgent",
  "description": "Harness your AI coding agents — one desktop app for Claude Code, Codex, and any ACP agent",
  "author": {
    "name": "DUNHKpcc",
    "email": "sjh2329952249@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/DUNHKpcc/dpcc-harness",
  "repository": {
    "type": "git",
    "url": "https://github.com/DUNHKpcc/dpcc-harness.git"
  },
  "main": "electron/dist/main.js",
  "scripts": {
    "build:electron": "tsup --config tsup.electron.config.ts",
    "typecheck": "tsc --noEmit && pnpm typecheck:electron",
    "typecheck:electron": "tsc --noEmit -p electron/tsconfig.json",
    "dev": "concurrently \"vite\" \"pnpm build:electron --watch\" \"node scripts/delay.js http://localhost:5173/ electron/dist/main.js && cross-env ELECTRON_ENABLE_LOGGING=1 electron .\"",
    "build": "pnpm build:electron && vite build",
    "start": "electron .",
    "workflow:doctor": "bash scripts/agent-workflow/doctor.sh",
    "workflow:start": "bash scripts/agent-workflow/start.sh",
    "workflow:hook": "bash scripts/agent-workflow/hook.sh",
    "workflow:handoff": "bash scripts/agent-workflow/handoff.sh",
    "workflow:record": "bash scripts/agent-workflow/record.sh",
    "workflow:review": "bash scripts/agent-workflow/review.sh",
    "workflow:status": "bash scripts/agent-workflow/status.sh",
    "workflow:subagent": "bash scripts/agent-workflow/subagent.sh",
    "workflow:stop": "bash scripts/agent-workflow/stop.sh",
    "bundle:codex": "node scripts/bundle-codex.js",
    "bundle:portable-git": "node scripts/bundle-portable-git.js",
    "dist": "pnpm build && pnpm bundle:codex && electron-builder --config electron-builder.config.js",
    "dist:fast": "pnpm build && pnpm bundle:codex && electron-builder --config electron-builder.config.js --dir",
    "dist:mac": "pnpm build && node scripts/bundle-codex.js --triples aarch64-apple-darwin && electron-builder --mac --arm64 --config electron-builder.config.js",
    "dist:win": "pnpm build && node scripts/bundle-codex.js --triples x86_64-pc-windows-msvc && node scripts/bundle-portable-git.js --platform win32 --arch x64 && electron-builder --win --x64 --config electron-builder.config.js",
    "dist:linux": "pnpm build && node scripts/bundle-codex.js --triples x86_64-unknown-linux-gnu,aarch64-unknown-linux-gnu && electron-builder --linux --config electron-builder.config.js",
    "postinstall": "node -e \"require('child_process').execSync('electron-rebuild'+(process.platform==='darwin'?'':' --ignore electron-liquid-glass'),{stdio:'inherit'})\"",
    "test": "vitest run --config vitest.config.electron.ts",
    "test:watch": "vitest --config vitest.config.electron.ts"
  },
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "@anthropic-ai/sdk": "^0.110.0",
    "@fontsource-variable/noto-serif-sc": "^5.2.10",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/instrument-serif": "^5.2.8",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@posthog/react": "^1.8.2",
    "@tanstack/react-virtual": "^3.13.22",
    "dompurify": "^3.3.3",
    "electron-context-menu": "^4.1.1",
    "electron-liquid-glass": "github:darkkatarsis/electron-liquid-glass",
    "electron-updater": "^6.8.3",
    "i18next": "^26.3.1",
    "konva": "^10.2.0",
    "mermaid": "^11.13.0",
    "motion": "^12.34.3",
    "node-pty": "^1.1.0",
    "posthog-js": "^1.360.0",
    "posthog-node": "^4.3.1",
    "qrcode": "^1.5.4",
    "react-i18next": "^17.0.8",
    "react-konva": "^19.2.3",
    "refractor": "^5.0.0",
    "sonner": "^2.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/dompurify": "^3.2.0",
    "@types/hast": "^3.0.4",
    "@types/node": "^25.2.3",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "diff": "^8.0.3",
    "electron": "^40.4.0",
    "electron-builder": "^26.8.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^3.8.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.206",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "0.3.206",
    "@anthropic-ai/claude-agent-sdk-linux-arm64": "0.3.206",
    "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "0.3.206",
    "@anthropic-ai/claude-agent-sdk-linux-x64": "0.3.206",
    "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "0.3.206",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "0.3.206",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.3.206"
  }
}
